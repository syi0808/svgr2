{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "node": true
  },
  "plugins": ["unicorn", "typescript", "oxc", "react"],
  "settings": {
    "react": {
      "version": "18.2.0"
    }
  },
  "ignorePatterns": [
    "node_modules/**",
    "**/__fixtures__/**",
    "__fixtures_build__/**",
    "coverage/**",
    "examples/**",
    "svgr.now.sh/**",
    "website/**",
    "**/dist/**",
    "packages/oxc-transform-svg-jsx-napi/binding.js"
  ],
  "rules": {
    "no-empty-function": "warn",
    "react/exhaustive-deps": "warn",
    "react/rules-of-hooks": "error"
  }
}
