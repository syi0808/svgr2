{
  "name": "@svgr2/plugin-jsx",
  "type": "module",
  "description": "Transform SVG into JSX",
  "version": "0.1.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "repository": "https://github.com/syi0808/svgr2/tree/main/packages/plugin-jsx",
  "author": "Yein Sung <syi778800@gmail.com>",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "svgr-plugin"
  ],
  "engines": {
    "node": ">=14"
  },
  "license": "MIT",
  "scripts": {
    "reset": "rm -rf dist",
    "build": "rollup -c ../../build/rollup.config.mjs",
    "prepublishOnly": "pnpm run reset && pnpm run build"
  },
  "dependencies": {
    "@babel/core": "^7.21.3",
    "@svgr2/babel-preset": "workspace:*",
    "@svgr2/hast-util-to-babel-ast": "workspace:*",
    "svg-parser": "^2.0.4"
  },
  "devDependencies": {
    "@svgr2/core": "workspace:*",
    "@types/svg-parser": "^2.0.3"
  },
  "peerDependencies": {
    "@svgr2/core": "*"
  }
}
