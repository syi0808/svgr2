{
  "name": "@svgr2/core",
  "type": "module",
  "description": "Transform SVG into React Components.",
  "version": "0.1.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "repository": "https://github.com/syi0808/svgr2/tree/main/packages/core",
  "author": "Yein Sung <syi778800@gmail.com>",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "svgr",
    "svg",
    "react",
    "core",
    "api"
  ],
  "engines": {
    "node": ">=14"
  },
  "license": "MIT",
  "scripts": {
    "reset": "rm -rf dist",
    "build": "rollup -c ../../build/rollup.config.mjs",
    "prepublishOnly": "npm run reset && npm run build"
  },
  "dependencies": {
    "@babel/core": "^7.21.3",
    "@svgr2/babel-preset": "workspace:*",
    "camelcase": "^6.2.0",
    "cosmiconfig": "^8.3.6",
    "snake-case": "^3.0.4"
  },
  "devDependencies": {
    "svgo": "^3.0.2"
  }
}
