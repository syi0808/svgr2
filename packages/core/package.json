{
  "name": "@svgr2/core",
  "type": "module",
  "description": "Transform SVG into React Components.",
  "version": "0.1.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "repository": "https://github.com/syi0808/svgr2/tree/main/packages/core",
  "author": "Yein Sung <syi778800@gmail.com>",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "svgr",
    "svg",
    "react",
    "core",
    "api"
  ],
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsdown",
    "test": "vitest"
  },
  "dependencies": {
    "change-case": "catalog:",
    "cosmiconfig": "catalog:"
  },
  "devDependencies": {
    "svgo": "catalog:",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  }
}