{
  "name": "@svgr2/cli",
  "type": "module",
  "description": "SVGR command line.",
  "version": "0.1.0",
  "repository": "https://github.com/syi0808/svgr2/tree/main/packages/cli",
  "author": "Yein Sung <syi778800@gmail.com>",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "svgr",
    "svg",
    "react",
    "cli"
  ],
  "engines": {
    "node": ">=14"
  },
