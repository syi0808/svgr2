{
  "name": "@svgr2/hast-util-to-babel-ast",
  "type": "module",
  "description": "Transform HAST to Babel AST (JSX)",
  "version": "0.1.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "repository": "https://github.com/syi0808/svgr2/tree/main/packages/hast-util-to-babel-ast",
  "author": "Yein Sung <syi778800@gmail.com>",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "html",
    "hast",
    "babel",
    "hast-util",
    "unist-util",
    "unist"
  ],
  "engines": {
    "node": ">=14"
  },
  "license": "MIT",
  "dependencies": {
    "@babel/types": "^7.21.3",
    "entities": "^4.4.0"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "vitest": "catalog:",
    "@types/svg-parser": "^2.0.3"
  }
}