{
  "name": "@svgr2/webpack",
  "description": "SVGR webpack loader.",
  "version": "0.1.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "repository": "https://github.com/syi0808/svgr2/tree/main/packages/webpack",
  "author": "Yein Sung <syi778800@gmail.com>",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "svgr",
    "svg",
    "react",
    "webpack",
    "webpack-loader"
  ],
  "engines": {
    "node": ">=14"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsdown",
    "test": "vitest"
  },
  "dependencies": {
    "@babel/core": "^7.21.3",
    "@babel/plugin-transform-react-constant-elements": "^7.21.3",
    "@babel/preset-env": "^7.20.2",
    "@babel/preset-react": "^7.18.6",
    "@babel/preset-typescript": "^7.21.0",
    "@svgr2/core": "workspace:*",
    "@svgr2/plugin-jsx": "workspace:*",
    "@svgr2/plugin-svgo": "workspace:*"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "vitest": "catalog:",
    "babel-loader": "^9.1.2",
    "memory-fs": "^0.5.0",
    "url-loader": "^4.1.1",
    "webpack": "^5.76.3"
  }
}