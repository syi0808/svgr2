{
  "name": "@svgr2/rollup",
  "type": "module",
  "description": "SVGR Rollup plugin.",
  "version": "0.1.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "repository": "https://github.com/syi0808/svgr2/tree/main/packages/rollup",
  "author": "Yein Sung <syi778800@gmail.com>",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "svgr",
    "svg",
    "react",
    "rollup",
    "rollup-plugin"
  ],
  "engines": {
    "node": ">=14"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsdown",
    "test": "vitest"
  },
  "dependencies": {
    "@babel/core": "^7.21.3",
    "@babel/plugin-transform-react-constant-elements": "^7.21.3",
    "@babel/preset-env": "^7.20.2",
    "@babel/preset-react": "^7.18.6",
    "@babel/preset-typescript": "^7.21.0",
    "@rollup/pluginutils": "^5.0.2",
    "@svgr2/core": "workspace:*",
    "@svgr2/plugin-jsx": "workspace:*",
    "@svgr2/plugin-svgo": "workspace:*"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "vitest": "catalog:",
    "rollup": "^3.20.2",
    "rollup-plugin-image": "^1.0.2",
    "rollup-plugin-url": "^3.0.1"
  }
}