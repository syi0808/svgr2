import * as React from "react";
import Svg, { Path } from "react-native-svg";
const SvgComponent = ({ title, titleId, ...props }) => <Svg aria-labelledby={titleId} {...props}>{title === undefined ? <title id={titleId || "a"}>{"Hello"}</title> : title ? <title id={titleId}>{title}</title> : null}<Path d="M0 0" /></Svg>;
export default SvgComponent;
